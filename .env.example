# Copy to .env and fill in real values. Never commit the real .env file.

PORT=8080
ENV=development

# Postgres connection string (e.g. Supabase, RDS, local docker)
DB=postgres://user:password@localhost:5432/adips?sslmode=disable

# Used to sign/verify JWTs — use a long random value in production
SECRET_KEY=change-me-to-a-long-random-string

# How long an issued JWT stays valid
JWT_EXPIRATION_HOURS=720
